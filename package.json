{
  "name": "tings",
  "version": "9.1.6",
  "private": false,
  "description": "A collection of small JavaScript utilities",
  "keywords": [
    "util",
    "utils",
    "utilities"
  ],
  "homepage": "https://tings.wstone.uk/",
  "bugs": {
    "url": "https://github.com/will-stone/tings/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/will-stone/tings.git"
  },
  "license": "MIT",
  "author": {
    "name": "Will Stone",
    "email": "hello@wstone.uk",
    "url": "https://wstone.uk"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "bench": "vitest bench",
    "build": "pnpm build:lib && pnpm build:web",
    "postbuild": "typedoc",
    "build:lib": "tsup source/index.ts --dts --format esm,cjs --clean",
    "build:web": "astro check && astro build",
    "dev": "concurrently 'pnpm dev:web' 'pnpm dev:lib' -n web,lib -c blue,magenta",
    "dev:lib": "pnpm build:lib -- --watch --onSuccess \"pnpm postbuild\"",
    "dev:web": "astro dev",
    "lint": "eslint .",
    "prepare": "husky",
    "release": "release-it",
    "test": "vitest",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "lint-staged": {
    "*.{css,json,md,js,jsx,ts,tsx,cjs,mjs}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx,cjs,mjs,json}": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "eslint": "$eslint",
    "typescript": "$typescript"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/tailwind": "^6.0.2",
    "@commits-with-character/conventional-changelog-preset": "^5.1.1",
    "@release-it/conventional-changelog": "^10.0.6",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.1.0",
    "@vitest/eslint-plugin": "^1.6.14",
    "@will-stone/eslint-config": "^26.2.0",
    "@will-stone/prettier-config": "^12.0.0",
    "astro": "^6.1.3",
    "astro-eslint-parser": "^1.4.0",
    "astro-remote": "^0.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "release-it": "^19.2.4",
    "tailwind-scrollbar": "^4.0.1",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.5.1",
    "typedoc": "~0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
